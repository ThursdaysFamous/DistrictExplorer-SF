__pycache__/
*.pyc

# Transient — created only when running scripts/smoke_test.mjs locally
# (`npm install playwright`). This project has no build step; none of these
# are committed.
node_modules/
package.json
package-lock.json

# Transient — Leaflet fetched by scripts/vendor_leaflet.sh so the smoke test can
# serve it same-origin where the browser can't reach the CDN (Claude Code web).
# Third-party asset, never committed; production and CI load Leaflet from the CDN.
scripts/vendor/

# Transient — outputs of scripts/perf_profile.mjs (the performance harness behind
# docs/PERFORMANCE_ANALYSIS_2026-07.md). Regenerated on demand; never committed.
perf-results.json
docs/perf-app-screenshot.png

# Transient — engine artifact outputs (docs/MECHANIZATION_PLAYBOOK.md, Conversion 1):
# `build_engine_artifact.py --out dist/` writes here, and `apply_engine.py`
# downloads the pinned release assets to the repo root when they're absent.
# engine.lock.json (the version + sha256 pin) IS committed — never ignore it.
dist/
/engine.bundle.js
/engine.manifest.json
